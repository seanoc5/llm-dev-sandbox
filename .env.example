# llm-dev-sandbox shipped defaults (safe-for-strangers values).
#
# Override per-project: copy into <project>/.swarm/.env (gitignored).
# Override per-invocation: set as shell env vars.
#
# Precedence (highest wins): shell env > <project>/.swarm/.env > this file.
#
# Loaded by llm-start.sh, coordinator-watch.sh, and provision-worker.sh via
# scripts/_load-env.sh, so all three converge on the same values.

# --- Worker provisioning ----------------------------------------------------

# Max concurrent worker tmux windows. Increase consciously — each worker
# is a Claude Code session and uses real RAM/VRAM/API quota.
MAX_WORKERS=2

# Hard cap on total tmux windows in the session (workers + system windows
# like coordinator/watch/status + leftover finished worker windows the user
# hasn't closed). provision-worker.sh refuses past this.
MAX_TMUX_WINDOWS=10

# Backlog target: housekeeping creates new issues if AVAILABLE issue count
# drops below this. AVAILABLE = open AND (assignee=@me OR no assignee) AND
# not blocked/deferred/awaiting-review AND not owner-labeled (other humans).
TARGET_AVAILABLE=5

# --- Issue filtering --------------------------------------------------------

# Comma-separated label names treated as "owned by a human" (in addition
# to gh assignees). Use on projects with a labels-as-owners convention.
# The coordinator skips issues bearing any owner-label that is NOT @me's
# GitHub login. Example: OWNER_LABELS=sean,radesh
OWNER_LABELS=

# Set to 1 to include issues assigned to others (overrides the @me-or-unassigned
# filter for sustained sprints where you're claiming teammates' work).
# Free-text override in the prompt ("grab anything", "regardless of assignee")
# also works for one-shot use without setting this.
INCLUDE_ASSIGNED_TO_OTHERS=0

# --- Watcher ----------------------------------------------------------------

# Seconds to coalesce repeated coordinator-wake events. Prevents thrash
# when many workers finish near-simultaneously.
DEBOUNCE_SECS=30

# Polling interval for the watcher's poll-mode fallback (used only when
# inotify-tools is not installed).
POLL_SECS=2

# tmux.conf.example — starter config tuned for the llm-dev-sandbox swarm workflow
#
# Copy to your home dir and reload:
#     cp examples/tmux.conf.example ~/.tmux.conf
#     tmux source-file ~/.tmux.conf            # reload in a running session
#
# Each block is independent — keep what you like, delete the rest.

# === Prefix key ============================================================
# Default Ctrl-b conflicts with readline backward-char (annoying in shell).
# Rebind to Ctrl-a (screen-compatible). If you're a heavy emacs user and
# Ctrl-a is sacred, leave this commented out and stick with Ctrl-b.
unbind C-b
set -g prefix C-a
bind C-a send-prefix     # Press Ctrl-a twice to send literal Ctrl-a

# === Sane defaults =========================================================

# Bigger scrollback buffer. The default is 2000 lines, which fills up fast
# when a Claude worker is mid-session. capture-pane -S -50000 lets you
# inspect the full history of a busy worker without losing context.
set -g history-limit 50000

# Reduce the escape-time so vim and other terminal apps respond instantly
# to ESC. Default 500ms makes ESC-based bindings feel laggy.
set -sg escape-time 10

# 1-index windows + panes (matches the number row on the keyboard so
# Prefix-1 jumps to the first window, not the second).
set -g base-index 1
setw -g pane-base-index 1

# Keep window slot numbers stable when a window closes — leave a gap rather
# than sliding higher-numbered windows down. In the swarm workflow, workers
# named iss-N live at specific slots; renumbering churns the slot/issue
# mapping and breaks muscle memory like "slot 7 = iss-5". The downside is a
# sparse status bar after a bunch of workers exit — flip this back to `on`
# if you bulk-close finished workers and prefer compact numbering.
set -g renumber-windows off

# Show window activity (a `*` next to a window in the status bar when
# something printed there since you last looked). Helpful for tracking
# which workers just produced output.
setw -g monitor-activity on
set -g visual-activity off    # Don't actively beep/flash; just annotate

# === Mouse mode ============================================================
# Click to switch panes/windows, scroll wheel to enter copy mode and
# scrollback. Disable if you hate it; some users find it interferes with
# their terminal's native mouse selection.
set -g mouse on

# === Vi-style copy mode (optional) =========================================
# Comment this block out if you prefer emacs-style bindings.
setw -g mode-keys vi
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -in -selection clipboard"
# (Replace `xclip` with `pbcopy` on macOS or `wl-copy` on Wayland.)

# === Multi-client sizing ===================================================
# When two clients of different sizes are attached to the same session,
# tmux fits to the smaller. `aggressive-resize` makes that per-window
# rather than per-session — windows currently focused by the smaller
# client shrink, but other windows keep the larger client's dimensions.
# Trade-off: helps the laptop+desk scenario but can confuse some apps.
setw -g aggressive-resize on

# === Status bar ============================================================
# Default status bar is fine; these tweaks make the swarm session info
# more visible. Window names stay short so iss-215 etc. fit cleanly.
set -g status-interval 5
set -g status-left  "#[bold]#S#[default] | "
set -g status-left-length 30
set -g status-right "#[fg=cyan]%H:%M #[fg=default]%Y-%m-%d"
setw -g window-status-format          " #I:#W "
setw -g window-status-current-format  "#[reverse] #I:#W #[default]"

# === Quick reload key ======================================================
# Prefix-r reloads this config without restarting tmux.
bind r source-file ~/.tmux.conf \; display-message "~/.tmux.conf reloaded"

# === Project-specific window-name tweaks ===================================
# When `llm-start.sh` spawns iss-N windows via `gh-status-bar.sh`, the
# session's status-right gets overwritten with live counts. To preserve
# your timestamp display in non-swarm sessions, the gh-status-bar script
# only modifies its own session — your other sessions stay as configured
# above.

# === Worker (iss-*) Ctrl-Z escape hatch ====================================
# In a worker window the foreground process is `docker run` and there is
# no host-side shell wrapping it — so a stray Ctrl-Z sends SIGTSTP straight
# to claude inside the container, suspending it with no easy way to `fg`.
#
# Intercept Ctrl-Z in iss-* windows: split a sibling pane that `docker
# exec`s into the SAME worker container as a login shell. claude keeps
# running in the original pane; you get a bash with the worktree, branch,
# and gh auth already in place. In any non-iss window, Ctrl-Z falls
# through to its normal behavior.
#
# Requires that provision-worker.sh names containers `swarm-<session>-<window>`
# (the default since v2). After adding this, run:
#   tmux source-file ~/.tmux.conf
#   tmux list-keys -T root | grep C-z      # verify it's now bound
#
# IMPORTANT: tmux's if-shell -F expands #{...} in the *condition*, but
# split-window's shell-command argument is passed literally (no format
# substitution). So we cannot put #{session_name}/#{window_name} in the
# docker exec line directly — they'd reach docker unexpanded and exit 1.
# tmux-worker-shell.sh resolves them at run time via `tmux display-message
# -p -t "$TMUX_PANE"`, which does expand formats.
#
# Adjust the absolute path below to where you cloned llm-dev-sandbox.
bind-key -n C-z if-shell -F '#{m:iss-*,#{window_name}}' \
    'split-window -h "/opt/work/sysadmin/llm-dev-sandbox/scripts/tmux-worker-shell.sh"' \
    'send-keys C-z'

# === Session persistence (tmux-resurrect + tmux-continuum) =================
# Survives tmux server restarts (intentional or crash). Without this, a
# killed tmux server loses every worker REPL, the coordinator state, and
# the entire window layout — mid-sprint, that's painful. With it:
#
#   • Layout (sessions, windows, panes, splits, working dirs) is saved.
#   • Pane contents (scrollback) are captured so post-mortem reads still work.
#   • Listed processes are *relaunched* on restore (claude/codex/gemini etc.).
#     Note this restarts the agent fresh — it does NOT restore the agent's
#     prior conversation state. Use claude's /resume or the coordinator's
#     own on-disk state (.swarm/) for that.
#
# One-time setup (TPM = Tmux Plugin Manager):
#   git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
#   tmux source-file ~/.tmux.conf
#   <prefix>+I        # install plugins
#
# Manual save:    <prefix>+Ctrl-s
# Manual restore: <prefix>+Ctrl-r
# Auto-save runs every @continuum-save-interval minutes; auto-restore fires
# when the tmux server starts and finds a saved state.

set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

# Capture pane scrollback so a restored window shows the same contents
# (not just a re-launched shell at an empty prompt).
set -g @resurrect-capture-pane-contents 'on'

# Programs to RELAUNCH on restore. Default list is conservative (vi, vim,
# nvim, emacs, man, less, more, tail, top, htop, irssi, weechat, mutt).
# Adding the swarm agents here makes the coordinator + worker windows
# come back as running processes instead of empty shells.
set -g @resurrect-processes 'btop htop mc vim nvim claude codex gemini'

# Continuum: auto-save every N minutes; auto-restore on tmux start.
set -g @continuum-restore 'on'
set -g @continuum-save-interval '15'

# Initialize TPM — MUST be the last line of this file.
run '~/.tmux/plugins/tpm/tpm'
